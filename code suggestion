# 2. `portfolio_construction/ap_tree_portfolios.py`에 추가할 함수

이 파일 맨 아래에 아래 함수를 붙여줘.

```python
def extract_tree_leaf_rules(tree, feature_names):
    """
    Extract human-readable decision rules for each terminal leaf of a fitted
    sklearn DecisionTreeRegressor.

    Returns one row per leaf.
    """
    import pandas as pd
    from collections import Counter

    sklearn_tree = tree.tree_
    rows = []

    def walk(node_id, path, depth):
        left_child = sklearn_tree.children_left[node_id]
        right_child = sklearn_tree.children_right[node_id]

        is_leaf = left_child == right_child

        if is_leaf:
            split_features = [step["feature"] for step in path]
            feature_counts = Counter(split_features)

            row = {
                "node_id": int(node_id),
                "depth": int(depth),
                "path": " & ".join(
                    [
                        f'{step["feature"]} {step["direction"]} {step["threshold"]:.6f}'
                        for step in path
                    ]
                ) if path else "root",
                "feature_order": ">".join(split_features) if split_features else "root",
                "feature_set": "+".join(sorted(set(split_features))) if split_features else "root",
                "n_splits": len(split_features),
                "n_unique_features": len(set(split_features)),
            }

            for feature, count in feature_counts.items():
                row[f"count_{feature}"] = int(count)

            rows.append(row)
            return

        feature = feature_names[sklearn_tree.feature[node_id]]
        threshold = float(sklearn_tree.threshold[node_id])

        walk(
            left_child,
            path + [{"feature": feature, "direction": "<=", "threshold": threshold}],
            depth + 1,
        )

        walk(
            right_child,
            path + [{"feature": feature, "direction": ">", "threshold": threshold}],
            depth + 1,
        )

    walk(0, [], 0)

    return pd.DataFrame(rows)
```

이 함수는 fitted decision tree를 읽어서 leaf node별로 “어떤 characteristic 순서로 split됐는지”를 뽑아줘.

