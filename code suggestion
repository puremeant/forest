# 5. stability 분석용 새 파일 만들기

새 파일을 하나 만들어.

파일명:

```text
analyze_tree_stability.py
```

내용:

```python
import itertools
from pathlib import Path

import pandas as pd


INPUT_FILE = Path("results/data/ap_tree_node_metadata.csv")
OUTPUT_DIR = Path("results/data/tree_stability")
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)


def jaccard_similarity(set_a, set_b):
    set_a = set(set_a)
    set_b = set(set_b)

    if len(set_a | set_b) == 0:
        return 0.0

    return len(set_a & set_b) / len(set_a | set_b)


def main():
    nodes = pd.read_csv(INPUT_FILE)

    date_cols = [
        "training_start_date",
        "training_end_date",
        "validation_start_date",
        "validation_end_date",
        "testing_start_date",
        "testing_end_date",
    ]

    for col in date_cols:
        if col in nodes.columns:
            nodes[col] = pd.to_datetime(nodes[col])

    nodes["window"] = (
        nodes["testing_start_date"].dt.strftime("%Y-%m-%d")
        + "_to_"
        + nodes["testing_end_date"].dt.strftime("%Y-%m-%d")
    )

    # ------------------------------------------------------------
    # 1. Feature frequency
    # ------------------------------------------------------------
    feature_rows = []

    for _, row in nodes.iterrows():
        if row["feature_order"] == "root":
            continue

        features = str(row["feature_order"]).split(">")

        for depth_position, feature in enumerate(features, start=1):
            feature_rows.append(
                {
                    "window": row["window"],
                    "testing_start_date": row["testing_start_date"],
                    "testing_end_date": row["testing_end_date"],
                    "characteristics": row["characteristics"],
                    "factors": row["factors"],
                    "ap_tree_max_depth": row["ap_tree_max_depth"],
                    "ap_tree_min_samples_leaf": row["ap_tree_min_samples_leaf"],
                    "node_id": row["node_id"],
                    "leaf_depth": row["depth"],
                    "depth_position": depth_position,
                    "feature": feature,
                }
            )

    feature_frequency = pd.DataFrame(feature_rows)

    feature_summary = (
        feature_frequency
        .groupby(
            [
                "characteristics",
                "factors",
                "ap_tree_max_depth",
                "ap_tree_min_samples_leaf",
                "feature",
            ],
            as_index=False,
        )
        .agg(
            total_uses=("feature", "size"),
            avg_depth_position=("depth_position", "mean"),
            n_windows=("window", "nunique"),
        )
        .sort_values(
            [
                "characteristics",
                "factors",
                "ap_tree_max_depth",
                "total_uses",
            ],
            ascending=[True, True, True, False],
        )
    )

    feature_frequency.to_csv(OUTPUT_DIR / "feature_frequency_by_window.csv", index=False)
    feature_summary.to_csv(OUTPUT_DIR / "feature_frequency_summary.csv", index=False)

    # ------------------------------------------------------------
    # 2. Exact order stability
    #    Example: smb>hml is different from hml>smb
    # ------------------------------------------------------------
    order_summary = (
        nodes
        .groupby(
            [
                "characteristics",
                "factors",
                "ap_tree_max_depth",
                "ap_tree_min_samples_leaf",
                "feature_order",
            ],
            as_index=False,
        )
        .agg(
            count=("feature_order", "size"),
            n_windows=("window", "nunique"),
            avg_leaf_depth=("depth", "mean"),
            avg_n_stocks=("n_stocks", "mean"),
        )
        .sort_values(
            [
                "characteristics",
                "factors",
                "ap_tree_max_depth",
                "count",
            ],
            ascending=[True, True, True, False],
        )
    )

    order_summary.to_csv(OUTPUT_DIR / "feature_order_summary.csv", index=False)

    # ------------------------------------------------------------
    # 3. Economic region stability ignoring order
    #    Example: smb>hml and hml>smb both become hml+smb
    # ------------------------------------------------------------
    feature_set_summary = (
        nodes
        .groupby(
            [
                "characteristics",
                "factors",
                "ap_tree_max_depth",
                "ap_tree_min_samples_leaf",
                "feature_set",
            ],
            as_index=False,
        )
        .agg(
            count=("feature_set", "size"),
            n_windows=("window", "nunique"),
            avg_leaf_depth=("depth", "mean"),
            avg_n_stocks=("n_stocks", "mean"),
        )
        .sort_values(
            [
                "characteristics",
                "factors",
                "ap_tree_max_depth",
                "count",
            ],
            ascending=[True, True, True, False],
        )
    )

    feature_set_summary.to_csv(OUTPUT_DIR / "feature_set_summary.csv", index=False)

    # ------------------------------------------------------------
    # 4. Window-to-window Jaccard similarity
    #    Higher value = more stable selected characteristic regions.
    # ------------------------------------------------------------
    group_cols = [
        "characteristics",
        "factors",
        "ap_tree_max_depth",
        "ap_tree_min_samples_leaf",
    ]

    similarity_rows = []

    for group_key, group_df in nodes.groupby(group_cols):
        window_to_orders = group_df.groupby("window")["feature_order"].apply(set).to_dict()
        window_to_sets = group_df.groupby("window")["feature_set"].apply(set).to_dict()

        windows = sorted(window_to_orders.keys())

        for w1, w2 in itertools.combinations(windows, 2):
            row = dict(zip(group_cols, group_key))
            row.update(
                {
                    "window_1": w1,
                    "window_2": w2,
                    "jaccard_feature_order": jaccard_similarity(
                        window_to_orders[w1],
                        window_to_orders[w2],
                    ),
                    "jaccard_feature_set": jaccard_similarity(
                        window_to_sets[w1],
                        window_to_sets[w2],
                    ),
                }
            )
            similarity_rows.append(row)

    similarity = pd.DataFrame(similarity_rows)
    similarity.to_csv(OUTPUT_DIR / "window_jaccard_similarity.csv", index=False)

    # ------------------------------------------------------------
    # 5. Compact stability report
    # ------------------------------------------------------------
    stability_report = (
        similarity
        .groupby(group_cols, as_index=False)
        .agg(
            avg_jaccard_feature_order=("jaccard_feature_order", "mean"),
            avg_jaccard_feature_set=("jaccard_feature_set", "mean"),
            min_jaccard_feature_order=("jaccard_feature_order", "min"),
            min_jaccard_feature_set=("jaccard_feature_set", "min"),
        )
        .sort_values(
            ["avg_jaccard_feature_set", "avg_jaccard_feature_order"],
            ascending=False,
        )
    )

    stability_report.to_csv(OUTPUT_DIR / "stability_report.csv", index=False)

    print("Saved stability outputs to:", OUTPUT_DIR)


if __name__ == "__main__":
    main()
```

